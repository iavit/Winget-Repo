#
# Winget-Repo environment example
# Copy this file to `.env` and adjust values for your environment.
#

# Server runtime
HOST=0.0.0.0
PORT=5000
WAITRESS_THREADS=8

# Flask-Limiter backend
# Production: use Redis or another shared backend, not memory://
FLASK_LIMITER_STORAGE_URI=redis://redis:6379/0

# SlowAPI backend for /client/api
# If omitted, app falls back to FLASK_LIMITER_STORAGE_URI
SLOWAPI_LIMITER_STORAGE_URI=redis://redis:6379/1
